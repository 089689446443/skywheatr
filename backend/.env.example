# ─────────────────────────────────────────────────────
# Skywheatr Backend — Environment Variables
# Salin file ini menjadi .env untuk development lokal
# ─────────────────────────────────────────────────────

# Mode: development | production
NODE_ENV=development

# Port server (Render akan otomatis set ini)
PORT=3000

# ── DATABASE ──────────────────────────────────────────
# PostgreSQL Connection String dari Neon (neon.tech)
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
#
# Cara dapat:
# 1. Daftar di https://neon.tech (gratis)
# 2. Buat project baru
# 3. Copy "Connection string" dari dashboard
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/skywheatr?sslmode=require

# ── CORS ──────────────────────────────────────────────
# URL Flutter Web setelah deploy ke Firebase Hosting
# Contoh: https://skywheatr-app.web.app
FRONTEND_URL=https://your-app.web.app
